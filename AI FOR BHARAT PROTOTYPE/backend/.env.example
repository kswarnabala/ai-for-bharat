# Backend Environment Variables
# Copy to .env and fill in your actual values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/evos_db?retryWrites=true&w=majority

# URL of your deployed ML service (FastAPI)
ML_API_URL=https://your-ml-service.railway.app

# Port (Railway/Render inject this automatically)
PORT=5000

# Your Vercel frontend URL (used for CORS whitelist)
FRONTEND_URL=https://your-app.vercel.app
