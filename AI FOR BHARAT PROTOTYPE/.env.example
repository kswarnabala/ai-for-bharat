# Frontend Environment Variables
# Copy this file to .env.local and fill in your deployed backend URLs

# Base URL for all REST API calls (no trailing slash)
# Example: https://your-backend.railway.app/api
VITE_API_BASE=https://your-backend.railway.app/api

# URL for Socket.IO connection (no trailing slash)
# Example: https://your-backend.railway.app
VITE_SOCKET_URL=https://your-backend.railway.app
